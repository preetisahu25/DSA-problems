class Solution {
public:
    int maximumDifference(vector<int>& nums) {
        int maxDiff = -1;
        int currMin = nums[0];

        for(int i = 1; i < nums.size(); i++) {
            if(nums[i] > currMin) {
                maxDiff = max(maxDiff, nums[i] - currMin);
            } else {
                currMin = nums[i];
            }
        }

        return maxDiff;
    }
};
