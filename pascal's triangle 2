class Solution {
public:
    vector<int> getRow(int rowIndex) {
    vector<int> row(rowIndex + 1);
    long long val = 1;

    for (int i = 0; i <= rowIndex; i++) {
        row[i] = val;
        val = val * (rowIndex - i) / (i + 1);
    }

    return row;
}

int main() {
    int rowIndex = 4;
    vector<int> result = getRow(rowIndex);

    for (int num : result) {
        cout << num << " ";
    }
    return 0;
}
};
