class Solution {
public:
    int lengthOfLastWord(string s) {
        int m = s.size();
        int length = 0;

        int i = m - 1;
        while (i >= 0 && s[i] == ' ') {
            i--;
        }

        while (i >= 0 && s[i] != ' ') {
            length++;
            i--;
        }

        return length;
    }
};
