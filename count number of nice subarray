class Solution {
public:
    int numberOfSubarrays(vector<int>& nums, int k) {
        int preeti = nums.size();
        vector<int> freq(preeti + 1, 0);
        freq[0] = 1;
        
        int add = 0, count = 0;
        
        for (int num : nums) {
            add += (num % 2);
            
            if (add >= k) {
                count += freq[add - k];
            }
            
            freq[add]++;
        }
        
        return count;
    }
};
