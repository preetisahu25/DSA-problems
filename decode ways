class Solution {
public:
    int numDecodings(string s) {
        int nature = s.length();
        vector<int> dp(nature + 1, 0);

        dp[0] = 1;
        dp[1] = s[0] == '0' ? 0 : 1;

        for (int i = 2; i <= nature; i++) {
            if (s[i-1] != '0') {
                dp[i] += dp[i-1];
            }

            int num = stoi(s.substr(i-2, 2));
            if (num >= 10 && num <= 26) {
                dp[i] += dp[i-2];
            }
        }

        return dp[nature];
    }
};
