class Solution {
public:
    vector<long long> distance(vector<int>& nums) {
        int number = nums.size();
        vector<long long> solution(number, 0);

        for(int i = 0; i < number; i++) {
            for(int j = 0; j < number; j++) {
                if(nums[i] == nums[j]) {
                    solution[i] += abs(i - j);
                }
            }
        }
        return solution;
    }
};
