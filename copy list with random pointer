class Solution {
public:
    Node* copyRandomList(Node* head) {
        if (!head) return NULL;

        Node* curr = head;
        while (curr) {
            Node* newNode = new Node(curr->val);
            newNode->next = curr->next;
            curr->next = newNode;
            curr = newNode->next;
        }

        curr = head;
        while (curr) {
            if (curr->random) {
                curr->next->random = curr->random->next;
            }
            curr = curr->next->next;
        }

        Node* dummy = new Node(0);
        Node* copy = dummy;
        curr = head;

        while (curr) {
            Node* nextOriginal = curr->next->next;

            copy->next = curr->next;
            copy = copy->next;
            
            curr->next = nextOriginal;
            curr = nextOriginal;
        }

        return dummy->next;
    }
};
