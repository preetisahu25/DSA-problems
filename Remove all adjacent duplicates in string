class Solution {
public:
    string removeDuplicates(string s){
        stack<char> st;

        for(char c : s) {
            if(!st.empty() && st.top() == c) {
                st.pop();
            } else {
                st.push(c);
            }
        }

        string solution = "";
        while(!st.empty()) {
            solution = st.top() + solution;
            st.pop();
        }

        return solution;
    }
        };
