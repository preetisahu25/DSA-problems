class Solution {
public:
    int findMiddleIndex(vector<int>& nums) {
        int preeti = nums.size();

        for (int i = 0; i < preeti; i++) {
            int leftSum = 0, rightSum = 0;

            for (int j = 0; j < i; j++)
                leftSum += nums[j];

            for (int j = i + 1; j < preeti; j++)
                rightSum += nums[j];

            if (leftSum == rightSum)
                return i;
        }
        return -1;
    }
};
