class Solution {
public:
    bool isPalindrome(string s) {
        string clean = "";

        for (char c : s) {
            if (isalnum(c)) {
                clean += tolower(c);
            }
        }

        stack<char> st;
        int n = clean.size();

        for (int i = 0; i < n / 2; i++) {
            st.push(clean[i]);
        }

        int start = (n % 2 == 0) ? n / 2 : n / 2 + 1;

        for (int i = start; i < n; i++) {
            if (st.top() != clean[i]) return false;
            st.pop();
        }

        return true;
    }
};
