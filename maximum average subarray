class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
         double sum=0;
       double  maxsum=0;
       int i=0;
       int n= nums.size();
        for(i=0; i<k; i++){
            sum+= nums[i];
        }
       maxsum  =sum;
        for(i=k; i<n; i++){
            sum += nums[i];
            sum-=nums[i-k];
            maxsum = max(sum,maxsum);
        }
        return maxsum/k;
    }
};
