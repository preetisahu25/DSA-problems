class Solution {
public:
    int numSubarrayProductLessThanK(vector<int>& nums, int k) {
        int n = nums.size();
        int count = 0;

        for (int i = 0; i < n; i++) {
            long long preeti = 1;
            for (int j = i; j < n; j++) {
                preeti *= nums[j];
                if (preeti < k) {
                    count++;
                } else {
                    break;
                }
            }
        }

        return count;
    }
}; 
