class Solution {
public:
    ListNode* sortList(ListNode* head) {
        vector<int> preeti;
        ListNode* temp = head;

        while (temp) {
            preeti.push_back(temp->val);
            temp = temp->next;
        }

        sort(preeti.begin(), preeti.end());

        temp = head;
        int i = 0;

        while (temp) {
            temp->val = preeti[i++];
            temp = temp->next;
        }

        return head;
    }
};
